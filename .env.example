# ── Nivora Interiors — Environment Variables ──────────────────────────────────
# Copy this file to .env for local development, or add each key/value in
# Netlify → Site configuration → Environment variables for production.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
API_PORT=3001

MONGODB_URI=your-mongodb-atlas-connection-string

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password
SESSION_SECRET=your-long-random-session-secret

EMAIL_USER=your-gmail-address
EMAIL_APP_SECRET=your-gmail-app-password
EMAIL_TO=your-inbox-email-address
